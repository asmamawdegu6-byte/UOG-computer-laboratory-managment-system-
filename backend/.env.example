# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/CLMS

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=24h

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin Default Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Telegram Bot Configuration (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Use either TWILIO_PHONE_NUMBER or TWILIO_MESSAGING_SERVICE_SID.
# If you use a Messaging Service, it must contain at least one SMS-capable sender.
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=your_twilio_messaging_service_sid
# Optional Twilio Verify Service for OTP password resets.
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# SuperAdmin Password Reset Phone Number
SUPERADMIN_PHONE=0928886341
